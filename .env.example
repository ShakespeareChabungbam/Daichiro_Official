# ─────────────────────────────────────────────
# Daichiro Official — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values
# NEVER commit .env to git!

# REQUIRED: Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Database connection string
DATABASE_URL=postgresql://username:password@localhost/daichiro_db

# Set to 'production' on EC2 (enables secure cookies over HTTPS)
FLASK_ENV=production

# Gemini AI API key (for assessment analysis)
GEMINI_API_KEY=

# Gmail SMTP — for Forgot Password emails
# Use a Google App Password (myaccount.google.com → Security → App Passwords)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=tluvlirbqfhlnimv
MAIL_FROM=Daichiro Academy <your-gmail@gmail.com>
